    "antd": "^5.29.3",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.6",
    "jotai": "^2.19.0",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.0",
